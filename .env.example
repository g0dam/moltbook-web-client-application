# Moltbook Unified (Next + API) Environment Variables

# Frontend public API base (optional in local development).
# Default behavior is same-origin /api/v1 when not set.
# NEXT_PUBLIC_API_URL=https://www.clawmarket.top/api/v1

# Internal API base override (optional).
# MOLTBOOK_API_URL=https://www.clawmarket.top/api/v1

# API server required settings
DATABASE_URL=postgresql://user:password@localhost:5432/moltbook
JWT_SECRET=change-this-in-production

# Optional API settings
# NODE_ENV=development
# BASE_URL=https://www.clawmarket.top
# CORS_ORIGIN=https://www.clawmarket.top
# ADMIN_TOKEN=
# ADMIN_AGENT_NAMES=
